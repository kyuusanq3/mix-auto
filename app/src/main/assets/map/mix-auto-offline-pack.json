{
  "version": 8,
  "name": "Mix Auto Offline Pack",
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#f8f4f0" }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "paint": { "fill-color": "rgb(158,189,255)" }
    },
    {
      "id": "landcover_grass",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", ["get", "class"], "grass"],
      "paint": { "fill-color": "rgba(176, 213, 154, 1)", "fill-opacity": 0.3 }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "park",
      "paint": { "fill-color": "#d8e8c8", "fill-opacity": 0.7 }
    },
    {
      "id": "road_casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["!=", ["get", "class"], "path"], ["!=", ["get", "class"], "pedestrian"]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#e9ac77",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 10, 2, 14, 8, 17, 12]
      }
    },
    {
      "id": "road",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["!=", ["get", "class"], "path"], ["!=", ["get", "class"], "pedestrian"]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#ffffff",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 10, 1, 14, 6, 17, 9]
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 13,
      "paint": { "fill-color": "hsl(35,8%,85%)", "fill-opacity": 0.6 }
    }
  ]
}
